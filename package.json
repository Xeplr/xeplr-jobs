{
  "name": "@xeplr/jobs",
  "version": "2.0.0",
  "description": "Scheduled + manual action runner — cron picks jobs and hands them off to @xeplr/actions",
  "main": "index.js",
  "files": ["index.js", "lib/", "bin/", "models/", "migrations/"],
  "bin": {
    "xeplr-jobs-migrate": "./bin/migrate.js",
    "xeplr-jobs-server": "./bin/server.js"
  },
  "exports": {
    ".": "./index.js",
    "./bin/server": "./bin/server.js",
    "./package.json": "./package.json"
  },
  "keywords": ["jobs", "queue", "background", "scheduler", "express", "cron"],
  "author": "xeplr",
  "license": "MIT",
  "repository": { "type": "git", "url": "https://github.com/Xeplr/xeplr-jobs" },
  "publishConfig": { "access": "public" },
  "dependencies": {
    "@xeplr/actions": "^1.0.0",
    "@xeplr/base-apis": "^1.0.0",
    "@xeplr/db": "^1.0.0",
    "@xeplr/schema-handler": "^1.0.0",
    "@xeplr/utils": "^1.0.0",
    "cron-parser": "^4.9.0"
  },
  "peerDependencies": {
    "express": "^4.0.0 || ^5.0.0"
  }
}
